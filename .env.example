# --- Auth ---
# Password for logging into the editor/API (no default: required).
AUTH_PASSWORD=your_password_here
# Optional explicit session signing key; defaults to AUTH_PASSWORD if unset.
# SECRET_KEY=
# Session lifetime in seconds (default: 1 year).
# SESSION_MAX_AGE=31536000
# Set to false for local HTTP development (cookie Secure flag).
# COOKIE_SECURE=true

# --- MQTT broker / zigbee2mqtt (your own service: address is required) ---
MQTT_HOST=your_mqtt_host_here
# MQTT_PORT=1883
# MQTT_USERNAME=
# MQTT_PASSWORD=
# Z2M_BASE=zigbee2mqtt

# --- App ---
# APP_TITLE=Z2M Floorplan
# PORT=8000
# LOG_LEVEL=INFO

# --- Runtime state paths (under data/, mounted as a docker volume) ---
# CONFIG_PATH=data/config.json
# ICON_PATH=data/icon.png
